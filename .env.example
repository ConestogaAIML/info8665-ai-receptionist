# =============================================================================
# AI Receptionist — Secrets Management (.env.example)
# Copy to `.env` and fill in real values. Never commit `.env`.
# Docker Compose reads these via ${VAR} substitution.
# =============================================================================

# --- Database secrets ---
DB_USERNAME=receptionist
DB_PASSWORD=changeme-db-password
DB_HOSTNAME=localhost
DB_PORT=5432
DB_NAME=ai_receptionist
# sqlite (default) or postgresql
DB_ENGINE=sqlite
SQLITE_DB_PATH=./data/receptionist.db

# --- Auth ---
JWT_SECRET_KEY=dev-secret-change-in-production

# --- Logging / API ---
LOG_FILE_PATH=logs/app.log
LOG_LEVEL=INFO
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- EDA feature names (comma-separated) ---
FEATURE_NAMES=Age,WaitingDays,AppointmentWeekday,AppointmentHour,SMS_received
TARGET_COLUMN=No-show
PROCESSED_DATA_PATH=data/processed/processed_appointments.csv
MODEL_PATH=data/model/no_show_model.pkl

# --- Model training hyperparameters ---
ML_N_ESTIMATORS=100
ML_MAX_DEPTH=
ML_RANDOM_STATE=42
ML_TEST_SIZE=0.2
ML_EPOCHS=3

# --- Experiment metadata ---
EXPERIMENT_NAME=appointment-no-show
EXPERIMENT_VERSION=1.0.0
EXPECTED_ACCURACY=0.75
